# ════════════════════════════════════════════════════════════════════════════════
# MetaTrader MCP Server — Live Trading Configuration
# ════════════════════════════════════════════════════════════════════════════════

# ── MT5 Credentials (required) ──────────────────────────────────────────────────
LOGIN=12345678
PASSWORD=your_password
SERVER=YourBrokerServer

# ── MT5 Terminal Path (optional — auto-detected if unset) ──────────────────────
# Windows: C:\Program Files\MetaTrader 5\terminal64.exe
MT5_PATH=

# ── Transport (optional, default: sse) ──────────────────────────────────────────
# Options: sse | stdio | streamable-http
MCP_TRANSPORT=sse
MCP_HOST=0.0.0.0
MCP_PORT=8080

# ── Live Loop Timing ────────────────────────────────────────────────────────────
LIVE_SCHEDULER_INTERVAL=60       # minutes between conviction scans
LIVE_GUARD_INTERVAL=60           # seconds between guard checks
LIVE_HEARTBEAT_INTERVAL=300      # seconds between heartbeat checks

# ── Risk Management ─────────────────────────────────────────────────────────────
MAX_CONSECUTIVE_LOSSES=5         # emergency brake threshold
MAX_DRAWDOWN_PCT=30              # emergency brake threshold
MAX_DAILY_TRADES=3               # scheduler daily limit
MIN_CONFIDENCE=60                # minimum conviction score to trade
MAX_DAILY_DRAWDOWN_PCT=10        # per-day drawdown limit
